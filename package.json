{
  "name": "playcast",
  "version": "0.0.1",
  "description": "Record Playwright walkthroughs with zoom, keystroke overlays, and speed control",
  "keywords": [
    "playwright",
    "screencast",
    "recording",
    "walkthrough",
    "demo"
  ],
  "homepage": "https://github.com/kolodny/playcast#readme",
  "bugs": {
    "url": "https://github.com/kolodny/playcast/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolodny/playcast.git"
  },
  "license": "MIT",
  "author": "Moshe Kolodny",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demos": "for f in demos/*.ts; do tsx \"$f\"; done",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "playwright": "^1.52.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "playwright": ">=1.59.0"
  },
  "module": "./dist/index.js"
}
